 package studentgradetracker;
+import java.util.*;
+
 
 public class StudentGradeSystem {
+    public static void main(String[] args) {
+        Scanner scanner = new Scanner(System.in);
+        Map<String, List<Integer>> studentGrades = new HashMap<>();
+
+        boolean start = true;
+        while (start) {
+            System.out.println("\n====== Student Grade System ======");
+            System.out.println("1. Add Student Grade");
+            System.out.println("2. Remove Student");
+            System.out.println("3. Display All Students & Grades");
+            System.out.println("4. Display Average Grade");
+            System.out.println("5. Sort Students by Average Grade");
+            System.out.println("6. Exit");
+            System.out.print("Choose (1–6): ");
+
+            int choice = scanner.nextInt();
+            scanner.nextLine();
+
+            switch (choice) {
+                case 1:
+                    System.out.print("Enter student name: ");
+                    String name = scanner.nextLine();
+                    System.out.print("Enter grade (0–100): ");
+                    int grade = scanner.nextInt();
+                    studentGrades.putIfAbsent(name, new ArrayList<>());
+                    studentGrades.get(name).add(grade);
+                    System.out.println("Grade added.");
+                    break;
+
+                case 2:
+                    System.out.print("Enter student name to remove: ");
+                    String toRemove = scanner.nextLine();
+                    if (studentGrades.remove(toRemove) != null) {
+                        System.out.println(" Student removed.");
+                    } else {
+                        System.out.println(" Student not found.");
+                    }
+                    break;
+
+                case 3:
+                    if (studentGrades.isEmpty()) {
+                        System.out.println(" No students found.");
+                    } else {
+                        for (Map.Entry<String, List<Integer>> entry : studentGrades.entrySet()) {
+                            System.out.println(" " + entry.getKey() + ": " + entry.getValue());
+                        }
+                    }
+                    break;
+
+                case 4:
+                    System.out.print("Enter student name: ");
+                    String target = scanner.nextLine();
+                    List<Integer> grades = studentGrades.get(target);
+                    if (grades == null || grades.isEmpty()) {
+                        System.out.println(" Student not found or has no grades.");
+                    } else {
+                        double avg = grades.stream().mapToInt(Integer::intValue).average().orElse(0);
+                        System.out.println(" Average for " + target + ": " + avg);
+                    }
+                    break;
+
+                case 5:
+                    System.out.println("\n Students Sorted by Average Grade:");
+                    studentGrades.entrySet().stream()
+                            .sorted((e1, e2) -> {
+                                double avg1 = e1.getValue().stream().mapToInt(Integer::intValue).average().orElse(0);
+                                double avg2 = e2.getValue().stream().mapToInt(Integer::intValue).average().orElse(0);
+                                return Double.compare(avg2, avg1);
+                            })
+                            .forEach(e -> {
+                                double avg = e.getValue().stream().mapToInt(Integer::intValue).average().orElse(0);
+                                System.out.println(e.getKey() + " → " + e.getValue() + " | Avg: " + avg);
+                            });
+                    break;
+
+                case 6:
+                    start = false;
+                    System.out.println(" Exiting.");
+                    break;
+
+                default:
+                    System.out.println(" Invalid choice.");
+            }
+        }
+
+        scanner.close();
+    }
 }
