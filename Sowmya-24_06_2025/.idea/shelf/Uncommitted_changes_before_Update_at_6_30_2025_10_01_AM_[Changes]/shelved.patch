+    public Map<String, List<Employee>> buildManagerMap(List<Employee> employees) {
+        Map<String, List<Employee>> managerMap = new HashMap<>();
+        for (Employee emp : employees) {
+            managerMap
+                    .computeIfAbsent(emp.getManagerId(), k -> new ArrayList<>())
+                    .add(emp);
+        }
+        return managerMap;
+    }
+
+    public void buildHierarchy(Employee manager,
+                               Map<String, List<Employee>> mgrMap,
+                               Set<String> currentPath) {
+        if (currentPath.contains(manager.getEmpId())) {
+            System.out.println("Circular reference detected at: " + manager.getEmpId());
+            return;
+        }
+
+        currentPath.add(manager.getEmpId());
+
+        List<Employee> reports = mgrMap.get(manager.getEmpId());
+        if (reports == null) return;
+
+        for (Employee emp : reports) {
+            manager.addDirectReport(emp);
+            buildHierarchy(emp, mgrMap, currentPath);
+        }
+    }
+
+    public List<Employee> buildHierarchyTree(List<Employee> employees) {
+        Map<String, List<Employee>> managerMap = buildManagerMap(employees);
+        Map<String, Employee> empMap = new HashMap<>();
+        for (Employee emp : employees) {
+            empMap.put(emp.getEmpId(), emp);
+        }
+
+        List<Employee> roots = new ArrayList<>();
+        for (Employee emp : employees) {
+            String mgrId = emp.getManagerId();
+            if (mgrId == null || !empMap.containsKey(mgrId)) {
+                roots.add(emp);
+            }
+        }
+
+        for (Employee root : roots) {
+            buildHierarchy(root, managerMap, new HashSet<>());
+        }
+        return roots;
+    }
+
+
+    public void printHierarchy(Employee emp, String indent) {
+        System.out.println(indent + "- " + emp);
+        for (Employee report : emp.getDirectReports()) {
+            printHierarchy(report, indent + "   ");
+        }
+    }
+
+}
